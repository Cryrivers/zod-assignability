{
  "name": "zod-assignability",
  "version": "0.0.2",
  "description": "TypeScript extend behavior implementation for Zod schemas",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown src/index.ts",
    "test": "vitest run",
    "format": "prettier --write \"{src,tests}/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rational-studio/zod-assignability"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "zod",
    "typescript",
    "assignability",
    "type-checking"
  ],
  "author": "Zhongliang Wang",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  }
}
